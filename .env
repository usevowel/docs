# Voice Agent Configuration (optional)
# These variables pre-fill the voice agent configuration modal
# Users can also configure via the UI without setting these env vars

# App ID (required for hosted mode, also used for self-hosted when not using JWT)
VITE_VOWEL_APP_ID=your-app-id-from-vowel-to

# Realtime URL (optional - defaults to wss://realtime.vowel.to/v1 for hosted mode)
# Set this for self-hosted instances or custom realtime endpoints
VITE_VOWEL_URL=

# JWT mode: Set VITE_VOWEL_USE_JWT=true to use JWT instead of appId + URL
# The JWT token contains the realtime URL embedded in its payload
VITE_VOWEL_USE_JWT=false
VITE_VOWEL_JWT_TOKEN=your-jwt-token-with-embedded-url
