# Voice Agent Configuration (All Optional)
# These variables pre-fill the voice agent configuration modal for a zero-friction experience.
# If not set, users can configure voice access via the UI modal by clicking the voweldocs button.

## Hosted Mode (SaaS)
# Set this to pre-configure hosted mode (auto-uses wss://realtime.vowel.to/v1)
# VITE_VOWEL_APP_ID=your-app-id-from-vowel-to

## Self-Hosted Mode (Manual)
# Set these to pre-configure self-hosted mode with App ID + URL
# VITE_VOWEL_URL=wss://your-instance.com/realtime
# VITE_VOWEL_APP_ID=your-self-hosted-app-id

## Self-Hosted Mode (JWT)
# Set these to pre-configure JWT-based authentication
# The JWT token should contain the realtime URL in its payload (url/endpoint/rtu claim)
# VITE_VOWEL_USE_JWT=true
# VITE_VOWEL_JWT_TOKEN=your-jwt-token-with-embedded-url

## RAG Debug Tool (Development Only)
# Set to true to enable the RAG debug interface with STT transcripts and search results
# VITE_VOWEL_DEBUG_RAG=false
