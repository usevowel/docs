{
  "name": "@vowel.to/docs",
  "version": "1.0.0",
  "description": "Documentation for @vowel.to/client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run docs:dev",
    "docs:dev": "vitepress dev",
    "docs:build": "npm run docs:generate-api && vitepress build && rm -f .vitepress/dist/_redirects",
    "docs:preview": "vitepress preview",
    "docs:generate-api": "typedoc",
    "deploy": "bun run docs:build && bunx wrangler deploy",
    "deploy:preview": "bun run docs:build && bunx wrangler deploy --env preview"
  },
  "dependencies": {
    "@vowel.to/client": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.21.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "glob": "^11.0.3",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.22",
    "wrangler": "^3.96.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}