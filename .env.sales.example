# Copy to `.env.sales` (gitignored) and fill in values before `bun run deploy:sales`.
# Vite bakes these into the static bundle; they are not read from Wrangler at runtime.

## Required for hosted demo (default realtime URL)
VITE_VOWEL_APP_ID=

## Optional — override realtime URL (defaults to wss://realtime.vowel.to/v1 in the theme)
# VITE_VOWEL_URL=

## Optional — keep aligned with production sales build if needed
# VITE_VOWEL_USE_JWT=false
# VITE_VOWEL_JWT_TOKEN=
# VITE_VOWEL_DEBUG_RAG=false
